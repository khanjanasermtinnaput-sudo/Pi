# ── Local development ──────────────────────────────────────────────────────
# Point directly at the local FastAPI server.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Render production (experimentalServices) ───────────────────────────────
# Leave NEXT_PUBLIC_API_URL unset (or set to empty string).
# next.config.mjs rewrites /api/* → /_/backend/api/* automatically when
# the RENDER environment variable is present.
# NEXT_PUBLIC_API_URL=

# ── Optional ───────────────────────────────────────────────────────────────
# Required by the backend for AI-powered natural language parsing.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
